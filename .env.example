# LLM
OPENAI_API_KEY=sk-...
LLM_MODEL=gpt-4o
LLM_EXTRACTION_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
LLM_TIMEOUT_S=30

# Postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=sales_agent
POSTGRES_USER=sales
POSTGRES_PASSWORD=sales_pw

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_pw

# App
APP_ENV=dev
LOG_LEVEL=INFO
AUDIT_SALT=change-me-in-prod
API_HOST=0.0.0.0
API_PORT=8000
